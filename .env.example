# ai-books — environment variable reference.
#
# Copy to `.env` (gitignored) and fill in real values for local development.
# Never commit `.env`. Real tokens are blocked by gitleaks (.gitleaks.toml).
#
# All values below are PLACEHOLDERS and intentionally do not match real key
# formats — so this file is safe to commit and is allowlisted in gitleaks.

# -----------------------------------------------------------------------------
# Runtime — ai-books MCP server (storage: Supabase / Postgres)
#
# The system of record is Supabase (Postgres). See ADR 0001 and AGENTS.md.
# -----------------------------------------------------------------------------

# Postgres connection string used by the MCP server (raw SQL via psycopg).
#   - Local:      copy the DB URL printed by `supabase start`. The default is
#                 postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   - Production: the Supabase cloud connection string (Project Settings →
#                 Database → Connection string). Keep the real value in .env only.
AI_BOOKS_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# MCP transport (Issue #106). Default is stdio — the local Claude Desktop / CLI
# launches the process and talks over stdio; leaving these unset preserves that.
# Set AI_BOOKS_MCP_TRANSPORT=http to expose the tools over Streamable HTTP (a
# deliberate operator choice — never enabled implicitly; see ADR 0008). When http,
# the server binds AI_BOOKS_MCP_HOST:AI_BOOKS_MCP_PORT (defaults 127.0.0.1:8000).
# NOTE: the http path is FAIL-CLOSED (ADR 0008, Issue #107): it refuses to start
# unless the auth block below is configured, so the remote endpoint is never opened
# without the Supabase Auth + single-user allowlist gate in front of it.
# AI_BOOKS_MCP_TRANSPORT=stdio
# AI_BOOKS_MCP_HOST=127.0.0.1
# AI_BOOKS_MCP_PORT=8000

# Remote auth (Issue #107). Gates the http transport: a request must carry a valid
# Supabase-issued JWT AND its identity (sub / email) must be in the allowlist — every
# other identity is denied even with a valid token (single-user authorization, ADR
# 0008). Unset = remote auth disabled (http then refuses to start; stdio is unaffected
# and always runs unauthenticated with the default audit actor).
#   - AI_BOOKS_MCP_AUTH_ALLOWLIST: comma/space-separated owner sub(s) or email(s).
#     Its presence ENABLES remote auth; SUPABASE_URL + AI_BOOKS_MCP_BASE_URL are then
#     required. JWT verification reuses SUPABASE_URL (below) for the JWKS / issuer.
#   - AI_BOOKS_MCP_BASE_URL: the public URL this server is reachable at (advertised to
#     OAuth clients as the protected resource).
#   - AI_BOOKS_MCP_AUTH_JWT_ALGORITHM: RS256 or ES256 (default ES256); must match the
#     Supabase Auth JWT signing key configuration.
# AI_BOOKS_MCP_AUTH_ALLOWLIST=00000000-0000-0000-0000-000000000000,owner@example.com
# AI_BOOKS_MCP_BASE_URL=https://your-mcp-server.example.com
# AI_BOOKS_MCP_AUTH_JWT_ALGORITHM=ES256

# The read-only Vercel viewer (web/) reads through this SAME variable, but in
# Production it should point at a SELECT-only Postgres role so the viewer cannot
# write even in principle (AGENTS.md invariant #1, enforced by
# tests/test_readonly_db.py). Create the role from the committed grant script and
# give it a login + password (this URL is the viewer's, kept in .env only):
#   psql "$ADMIN_DB_URL" -v ON_ERROR_STOP=1 -f supabase/roles/viewer_readonly.sql
#   ALTER ROLE viewer_ro WITH LOGIN PASSWORD '<strong-password>';
# AI_BOOKS_DB_URL=postgresql://viewer_ro:REPLACE_ME_EXAMPLE@127.0.0.1:54322/postgres

# Supabase project endpoint + keys, for Supabase client tooling / CLI.
# Anon key is browser-safe; the service-role key bypasses RLS and must stay
# server-side only — never ship it to the client. (The read-only Vercel viewer
# in web/ connects server-side via AI_BOOKS_DB_URL above, not via these keys —
# see web/README.md.)
#   Local:      values from `supabase start` output.
#   Production: Project Settings → API.
SUPABASE_URL=https://REPLACE_ME_EXAMPLE.supabase.co
SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME_EXAMPLE_PLACEHOLDER
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME_EXAMPLE_PLACEHOLDER

# DEPRECATED (pre-ADR-0001 SQLite path). Storage moved to Supabase (Postgres);
# use AI_BOOKS_DB_URL instead. Retained only as a migration reference and will
# be removed once no tooling references it.
# AI_BOOKS_DB_PATH=~/.ai-books/db.sqlite

# e-Tax 申告者ヘッダ プロフィール (Issue #160). export_etax は、申告者の平文ヘッダ欄
# (住所 / 事業所所在地 / 加入団体名) を手編集 TOML から自動供給する。既定の置き場所は
# ~/.ai-books/etax/profile.toml (秘匿情報を repo に入れないため ~/.ai-books 配下)。未設定なら
# 従来通り空欄。この変数で別パスへ上書きできる (主にテスト用 — 実 ~/.ai-books に触れない)。
# テンプレートと対応様式コードは docs/etax/README.md「申告者ヘッダ プロフィール」を参照。
# 氏名・フリガナ・屋号・業種名・電話 は様式上 e-Tax ソフトの利用者情報側が持つため対象外。
# AI_BOOKS_ETAX_PROFILE=~/.ai-books/etax/profile.toml

# -----------------------------------------------------------------------------
# AI-assisted development (Claude Code / Codex / etc.)
#
# Used by tooling and agents running locally — not by the MCP server itself.
# -----------------------------------------------------------------------------

# Anthropic API key for Claude Code / direct API calls.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME_EXAMPLE_PLACEHOLDER

# OpenAI API key for Codex CLI / direct API calls.
OPENAI_API_KEY=sk-proj-REPLACE_ME_EXAMPLE_PLACEHOLDER

# GitHub personal access token used by `gh` CLI and CI helpers.
# Prefer fine-grained tokens scoped to this repo only.
GITHUB_TOKEN=github_pat_REPLACE_ME_EXAMPLE_PLACEHOLDER

# -----------------------------------------------------------------------------
# Future integrations (accounting data sources)
#
# Wired up in later roadmap issues — listed here so gitleaks rules and
# .gitignore behaviour are in place before the first real credential lands.
# -----------------------------------------------------------------------------

# freee (https://developer.freee.co.jp/) — OAuth 2.0
# FREEE_CLIENT_ID=REPLACE_ME
# FREEE_CLIENT_SECRET=REPLACE_ME_EXAMPLE_PLACEHOLDER
# FREEE_ACCESS_TOKEN=REPLACE_ME_EXAMPLE_PLACEHOLDER
# FREEE_REFRESH_TOKEN=REPLACE_ME_EXAMPLE_PLACEHOLDER

# MoneyForward (https://biz.moneyforward.com/) — OAuth 2.0
# MF_CLIENT_ID=REPLACE_ME
# MF_CLIENT_SECRET=REPLACE_ME_EXAMPLE_PLACEHOLDER
# MF_ACCESS_TOKEN=REPLACE_ME_EXAMPLE_PLACEHOLDER

# Plaid (https://plaid.com/) — bank / card aggregation
# PLAID_CLIENT_ID=REPLACE_ME
# PLAID_SECRET=REPLACE_ME_EXAMPLE_PLACEHOLDER
# PLAID_ENV=sandbox
