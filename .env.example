# ai-books — environment variable reference.
#
# Copy to `.env` (gitignored) and fill in real values for local development.
# Never commit `.env`. Real tokens are blocked by gitleaks (.gitleaks.toml).
#
# All values below are PLACEHOLDERS and intentionally do not match real key
# formats — so this file is safe to commit and is allowlisted in gitleaks.

# -----------------------------------------------------------------------------
# Runtime — ai-books MCP server (storage: Supabase / Postgres)
#
# The system of record is Supabase (Postgres). See ADR 0001 and AGENTS.md.
# -----------------------------------------------------------------------------

# Postgres connection string used by the MCP server (raw SQL via psycopg).
#   - Local:      copy the DB URL printed by `supabase start`. The default is
#                 postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   - Production: the Supabase cloud connection string (Project Settings →
#                 Database → Connection string). Keep the real value in .env only.
AI_BOOKS_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase project endpoint + keys, consumed by the read-only Vercel viewer
# (and any Supabase client tooling). Anon key is browser-safe; the service-role
# key bypasses RLS and must stay server-side only — never ship it to the client.
#   Local:      values from `supabase start` output.
#   Production: Project Settings → API.
SUPABASE_URL=https://REPLACE_ME_EXAMPLE.supabase.co
SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME_EXAMPLE_PLACEHOLDER
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME_EXAMPLE_PLACEHOLDER

# DEPRECATED (pre-ADR-0001 SQLite path). Storage moved to Supabase (Postgres);
# use AI_BOOKS_DB_URL instead. Retained only as a migration reference and will
# be removed once no tooling references it.
# AI_BOOKS_DB_PATH=~/.ai-books/db.sqlite

# -----------------------------------------------------------------------------
# AI-assisted development (Claude Code / Codex / etc.)
#
# Used by tooling and agents running locally — not by the MCP server itself.
# -----------------------------------------------------------------------------

# Anthropic API key for Claude Code / direct API calls.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME_EXAMPLE_PLACEHOLDER

# OpenAI API key for Codex CLI / direct API calls.
OPENAI_API_KEY=sk-proj-REPLACE_ME_EXAMPLE_PLACEHOLDER

# GitHub personal access token used by `gh` CLI and CI helpers.
# Prefer fine-grained tokens scoped to this repo only.
GITHUB_TOKEN=github_pat_REPLACE_ME_EXAMPLE_PLACEHOLDER

# -----------------------------------------------------------------------------
# Future integrations (accounting data sources)
#
# Wired up in later roadmap issues — listed here so gitleaks rules and
# .gitignore behaviour are in place before the first real credential lands.
# -----------------------------------------------------------------------------

# freee (https://developer.freee.co.jp/) — OAuth 2.0
# FREEE_CLIENT_ID=REPLACE_ME
# FREEE_CLIENT_SECRET=REPLACE_ME_EXAMPLE_PLACEHOLDER
# FREEE_ACCESS_TOKEN=REPLACE_ME_EXAMPLE_PLACEHOLDER
# FREEE_REFRESH_TOKEN=REPLACE_ME_EXAMPLE_PLACEHOLDER

# MoneyForward (https://biz.moneyforward.com/) — OAuth 2.0
# MF_CLIENT_ID=REPLACE_ME
# MF_CLIENT_SECRET=REPLACE_ME_EXAMPLE_PLACEHOLDER
# MF_ACCESS_TOKEN=REPLACE_ME_EXAMPLE_PLACEHOLDER

# Plaid (https://plaid.com/) — bank / card aggregation
# PLAID_CLIENT_ID=REPLACE_ME
# PLAID_SECRET=REPLACE_ME_EXAMPLE_PLACEHOLDER
# PLAID_ENV=sandbox
