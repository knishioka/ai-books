# ai-books viewer — environment variables.
#
# Copy to web/.env.local (gitignored) for local development. The DB connection is
# read SERVER-SIDE only; the Supabase Auth values below are public by design (they
# ship to the browser so the login client can manage the session cookie).

# Postgres connection string for the read-only viewer (server-side only).
#   - Local:      the DB URL printed by `supabase start` (same value the MCP
#                 server uses). The Supabase CLI default is:
#                 postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   - Production: set this in the Vercel project (Preview/Production env). Use a
#                 READ-ONLY Postgres role so the viewer cannot mutate data even
#                 in principle. See web/README.md.
AI_BOOKS_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Supabase Auth login gate (issue #108 / ADR 0008) -----------------------
# The viewer is gated behind Supabase Auth: every route requires login. These two
# values are the Supabase project URL and the *anon* (publishable) key — public by
# design, so they use the NEXT_PUBLIC_ prefix and reach the browser. They are NOT
# secrets (no service-role key is ever shipped to the viewer).
#   - Local:      values from `supabase start` output (API URL + anon key).
#   - Production: set in the Vercel project (Preview/Production env).
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_ME_EXAMPLE.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME_EXAMPLE_PLACEHOLDER

# Single-user allowlist (ADR 0008): the one owner email authorized to view. A valid
# Supabase session whose email differs is denied (fail closed). Server-side only —
# never shipped to the browser. Leave unset to allow any authenticated Supabase user
# (authentication-only gate); set it to enforce the single-owner authorization layer.
AUTH_ALLOWED_EMAIL=owner@example.com
