{
  "name": "ai-books-web",
  "version": "0.0.0",
  "private": true,
  "description": "ai-books read-only viewer (Vercel). Renders Supabase/Postgres data; no data entry.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:golden": "tsx scripts/verify-golden.ts",
    "e2e": "playwright test",
    "e2e:visual": "bash scripts/visual-docker.sh",
    "e2e:visual:update": "bash scripts/visual-docker.sh --update-snapshots"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "next": "^16.2.7",
    "postgres": "^3.4.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.7",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
