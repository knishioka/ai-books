{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./scripts/verify.sh)",
      "Bash(./scripts/verify.sh:*)",
      "Bash(./scripts/test.sh)",
      "Bash(./scripts/test.sh:*)",
      "Bash(uv run:*)",
      "Bash(uv sync)",
      "Bash(uv sync:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run pre-commit:*)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npm run:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose exec:*)",
      "Bash(docker compose build:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose stop:*)",
      "Bash(docker compose start:*)",
      "Bash(docker compose down)",
      "Bash(supabase start)",
      "Bash(supabase stop)",
      "Bash(supabase status)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force)",
      "Bash(git push --force:*)",
      "Bash(git push:* --force)",
      "Bash(docker compose down --volumes)",
      "Bash(docker compose down --volumes:*)",
      "Bash(docker compose down -v)",
      "Bash(docker compose down -v:*)",
      "Bash(docker volume rm:*)",
      "Bash(supabase db push)",
      "Bash(supabase db push:*)",
      "Bash(supabase db reset)",
      "Bash(supabase db reset:*)",
      "Edit(./uv.lock)",
      "Write(./uv.lock)",
      "Write(~/.ai-books/**)",
      "Edit(~/.ai-books/**)",
      "Write(./.ai-books/**)",
      "Edit(./.ai-books/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-never-touch.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-after-edit.py\""
          }
        ]
      }
    ]
  }
}
